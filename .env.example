# Database
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/rag_pipeline

# OpenAI (for embeddings and LLM)
OPENAI_API_KEY=sk-your-key-here

# Embedding config
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# LLM config
LLM_MODEL=gpt-4o-mini

# Ingestion
SEC_EDGAR_USER_AGENT=YourName your@email.com
DATA_DIR=./data
LANDING_DIR=./data/landing
BRONZE_DIR=./data/bronze
SILVER_DIR=./data/silver
GOLD_DIR=./data/gold

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=10
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6

# Freshness
STALENESS_CHECK_INTERVAL_HOURS=6
MAX_EMBEDDING_LAG_MINUTES=30
